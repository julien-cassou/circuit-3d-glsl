/**
* Méthode qui parcours la List de Coords cactus, et les dessine un par un.
* On leur applique aussi le shader pour les .obj "voitureShader".
**/
void drawCactus() {
  if (modeNuit) {
    shader(voitureShader);
  } else {
    resetShader();
    lights();
  }

  // On dessine la forêt de cactus
  for (PVector p : cactusPos) {
    if (modeNuit) {
      voitureShader.set("voiturePos", p.x, - 25, p.z);
      voitureShader.set("circuitOffset", (float)circuitX, (float)circuitY, (float)circuitZ);
    }
    pushMatrix();
      translate(circuitX + p.x, circuitY - 25, circuitZ + p.z);
      rotateX(PI);
      scale(100);
      shape(cactus);
    popMatrix();
  }
}
